# ──────────
# PostgreSQL
# ──────────
POSTGRES_USER=ai_assistant
POSTGRES_PASSWORD=changeme
POSTGRES_DB=ai_assistant_db

# ───
# LLM
# ───
LLM_PROVIDER=groq
LLM_MODEL=groq/llama3-70b-8192
LLM_API_KEY=your_llm_api_key_here

# ──────────
# Embeddings
# ──────────
EMBEDDING_MODEL=intfloat/multilingual-e5-large
EMBEDDING_DIMENSION=1024

# ─────────
# Telegram
# ─────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ────
# App
# ────
APP_SECRET_KEY=change_this_to_random_secret
CHAT_HISTORY_WINDOW=10        # скользящее окно истории
RAG_TOP_K=5                   # сколько чанков брать из Qdrant

# ───────
# Logging
# ───────
SQL_DEBUG=False
LOG_LEVEL=INFO
SERVICE_NAME=ai-assistant-showcase
